# Local Docker Compose example.
# In Coolify, set these as shared/environment variables instead of committing real secrets.

POSTGRES_DB=devbills
POSTGRES_USER=devbills
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://devbills:replace-with-a-strong-password@postgres:5432/devbills

APP_PORT=3000
APP_IMAGE=dev-bills-app
